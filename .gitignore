# macOS
.DS_Store

# apps/ are tracked in this monorepo (fresh-snapshot migration 2026-06-20).
# Per-app .gitignore files still apply within each app subtree; nested .git
# histories were archived to backups/nested-git/ and to each origin repo.

# Database dumps and handoff material — never version data payloads at root
backups/
prod-db-handoff-2026-05-13/
*.dump
*.sql.gz
*.tar.gz.enc

# Screenshots / visual artifacts
artifacts/

# Env and secrets — templates are tracked, real env files never are
.env
.env.*
!.env.example
!**/.env.example
*.pem
*.key
*.p12
*.p8

# Build outputs
node_modules/
dist/
build/
.next/

# Turborepo cache
.turbo/
