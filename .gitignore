# macOS
.DS_Store

# apps/ are tracked in this monorepo (fresh-snapshot migration 2026-06-20).
# Per-app .gitignore files still apply within each app subtree.

# Local, non-repo working files — never version data payloads or scratch dirs
backups/
prod-db-handoff-2026-05-13/
*.dump
*.sql.gz
artifacts/
.hermes/
*.tar.gz.enc

# Screenshots / visual artifacts
artifacts/

# Env and secrets — templates are tracked, real env files never are
.env
.env.*
!.env.example
!**/.env.example
*.pem
*.key
*.p12
*.p8

# Build outputs
node_modules/
dist/
build/
.next/

# Exception: packages/tokens ships its generator (build/) AND its generated output
# (dist/) in git. The frontends deploy as separate Vercel projects that run an
# app-scoped `npm install` + `npm run build` and never execute the monorepo token
# generator, so the committed dist/ is what they consume. tokens-ci.yml keeps it fresh.
!packages/tokens/build/
!packages/tokens/build/**
!packages/tokens/dist/
!packages/tokens/dist/**

# Turborepo cache
.turbo/
.vercel
.env*

# Supabase CLI scratch. Written by `supabase link`/`db` commands; holds the linked
# project ref and a pooler URL. Machine-local state, not source — and umi-cash is
# frozen, so nothing here should ever be committed.
apps/*/supabase/.temp/

# Python bytecode caches. Build artifacts of whatever interpreter last ran; they
# are unreviewable binaries and version-specific (cpython-314 here).
__pycache__/
*.pyc
