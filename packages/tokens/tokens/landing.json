{
  "$description": "umi-landing-page (Next.js + Tailwind v3) design tokens, captured verbatim from apps/umi-landing-page/tailwind.config.js theme.extend. The three groups map directly onto Tailwind's theme.extend.{colors,fontFamily,letterSpacing}. Shared brand hues reference core; the marketing palette (paper/accent/alpha ramps) is landing-scoped and intentionally distinct from the console. Key order in the generated object is normalized (numeric alpha keys sort ahead of named keys) — Tailwind reads by key, so rendered CSS is unaffected.",
  "colors": {
    "umi-blue": {
      "dark": { "$type": "color", "$value": "{color.navy}" },
      "light": { "$type": "color", "$value": "{color.blue}" },
      "deep": { "$type": "color", "$value": "#0A1430" },
      "80": { "$type": "color", "$value": "rgba(34, 57, 121, 0.8)" },
      "60": { "$type": "color", "$value": "rgba(34, 57, 121, 0.6)" },
      "40": { "$type": "color", "$value": "rgba(34, 57, 121, 0.4)" }
    },
    "umi-light-blue": {
      "DEFAULT": { "$type": "color", "$value": "{color.blue}" },
      "soft": { "$type": "color", "$value": "#BFD1F2" },
      "80": { "$type": "color", "$value": "rgba(118, 146, 203, 0.8)" },
      "60": { "$type": "color", "$value": "rgba(118, 146, 203, 0.6)" },
      "40": { "$type": "color", "$value": "rgba(118, 146, 203, 0.4)" }
    },
    "umi-paper": { "$type": "color", "$value": "#FBF7EF" },
    "umi-paper-warm": { "$type": "color", "$value": "#EDE7DA" },
    "umi-accent": { "$type": "color", "$value": "#E7A85B" },
    "umi-ink": { "$type": "color", "$value": "#F2F6FF" }
  },
  "fontFamily": {
    "domus": { "$type": "fontFamily", "$value": ["var(--font-nunito)", "sans-serif"] },
    "sans": { "$type": "fontFamily", "$value": ["var(--font-nunito)", "sans-serif"] },
    "serif": { "$type": "fontFamily", "$value": ["var(--font-fraunces)", "Georgia", "serif"] },
    "mono": { "$type": "fontFamily", "$value": ["var(--font-source-code)", "monospace"] }
  },
  "letterSpacing": {
    "wider-2": { "$type": "dimension", "$value": "0.2em" },
    "wider-3": { "$type": "dimension", "$value": "0.22em" }
  }
}
