{
  "name": "@umi/contract",
  "version": "0.1.0",
  "private": true,
  "description": "Typed HTTP contract (route paths + zod schemas + inferred types) shared by umi-api and umi-dashboard so the API surface can't drift.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./routes": {
      "types": "./dist/routes.d.ts",
      "import": "./dist/routes.js",
      "require": "./dist/routes.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/routes.test.mjs"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "files": [
    "dist",
    "src"
  ]
}
