# ── umi-api environment ────────────────────────────────────────────────────
# Copy to .env and fill in. Config is validated at boot (src/shared/config);
# the process refuses to start if a required value is missing or malformed.

NODE_ENV=development
PORT=3000

# ── Database: two roles (spec §11.2) ───────────────────────────────────────
# umi_app    = RLS-enforced request role (web). Non-BYPASSRLS.
# umi_worker = BYPASSRLS service role (worker + queue/observability/grow).
# umi_readonly = analytics (optional).
DATABASE_URL_APP=postgresql://umi_app:CHANGE_ME@HOST:5432/postgres
DATABASE_URL_WORKER=postgresql://umi_worker:CHANGE_ME@HOST:5432/postgres
# DATABASE_URL_READONLY=postgresql://umi_readonly:CHANGE_ME@HOST:5432/postgres

# ── Redis / BullMQ ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Feature flags ──────────────────────────────────────────────────────────
# D11: keep cash writes inert until umi-cash is decommissioned.
CASH_WRITE_ENABLED=false

# ── Reverse proxy (Caddy) ──────────────────────────────────────────────────
# Use ":80" for local; a real hostname (api.umiconsulting.co) for the VPS so
# Caddy provisions TLS automatically.
API_DOMAIN=:80

# ── Added in later phases (kept commented so boot doesn't require them) ─────
# JWT_SECRET=                       # Phase 2 (auth)
# ANTHROPIC_API_KEY=                # Phase 3
# VOYAGE_API_KEY=                   # Phase 3
# TWILIO_ACCOUNT_SID=               # Phase 3
# TWILIO_AUTH_TOKEN=                # Phase 3
# TWILIO_WHATSAPP_FROM=             # Phase 3
# ZETTLE_CLIENT_ID=                 # Phase 3
# ZETTLE_API_KEY=                   # Phase 3
# SMTP_HOST=                        # Phase 2/5 (email)
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=hola@umiconsulting.co
# CORS_ORIGINS=https://dashboard.umiconsulting.co
