# ── umi-api environment ────────────────────────────────────────────────────
# Copy to .env and fill in. Config is validated at boot (src/shared/config);
# the process refuses to start if a required value is missing or malformed.

NODE_ENV=development
PORT=3000

# ── Database: two roles (spec §11.2) ───────────────────────────────────────
# umi_app    = RLS-enforced request role (web). Non-BYPASSRLS.
# umi_worker = BYPASSRLS service role (worker + queue/observability/grow).
# umi_readonly = analytics (optional).
DATABASE_URL_APP=postgresql://umi_app:CHANGE_ME@HOST:5432/postgres
DATABASE_URL_WORKER=postgresql://umi_worker:CHANGE_ME@HOST:5432/postgres
# DATABASE_URL_READONLY=postgresql://umi_readonly:CHANGE_ME@HOST:5432/postgres
# TLS: path to (or inline PEM of) the Postgres root CA. SET in prod (Supabase) to
# enforce verify-full on both pools; LEAVE UNSET locally (plaintext to localhost).
# Get it from Supabase → Project Settings → Database → SSL configuration. Do NOT add
# sslmode to the URLs above — this var governs TLS.
# PGSSLROOTCERT=/etc/umi/supabase-ca.crt

# ── Redis / BullMQ ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Observability ──────────────────────────────────────────────────────────
# Schema holding the runtime trace tables umi-logs reads (ai_turn_logs,
# edge_function_logs, security_logs, pipeline_traces). Live default below.
OBSERVABILITY_SCHEMA=conversaflow

# ── Feature flags ──────────────────────────────────────────────────────────
# D11: keep cash writes inert until umi-cash is decommissioned.
CASH_WRITE_ENABLED=false
# Phase 4: emit customer WhatsApp notifications on KDS status changes. Keep false
# until the iPad is repointed to umi-api + the kds-* edge functions are
# decommissioned (the legacy kds.transition_ticket RPC already sends these, so
# enabling early double-sends). Transitions still run when false.
KDS_STATUS_NOTIFY_ENABLED=false
# Phase 5: run the landing-page email-sequence tick (day 0/2/5/10/30 diagnostic
# follow-ups). Keep false until the landing page is repointed to umi-api and its
# own SQLite/Vercel cron is disabled (else prospects get double-mailed). Public
# contact/diagnostic routes are live regardless — only the background tick is gated.
LEADS_SEQUENCE_ENABLED=false

# ── Reverse proxy (Caddy) ──────────────────────────────────────────────────
# Use ":80" for local; a real hostname (api.umiconsulting.co) for the VPS so
# Caddy provisions TLS automatically.
API_DOMAIN=:80

# ── Auth (Phase 2, D9) — JWT access+refresh in httpOnly cookies ────────────
# JWT_SECRET is required for the dashboard auth API (≥16 chars). The TTL/cookie
# knobs have safe defaults; override COOKIE_SECURE=false only for local http.
# JWT_SECRET=                       # ≥16 chars; set a fresh, rotated value
# JWT_ACCESS_TTL=15m                # jose duration
# JWT_REFRESH_TTL=30d
# COOKIE_SECURE=true                # false for local http dev
# COOKIE_SAMESITE=lax               # lax | strict | none
# COOKIE_DOMAIN=.umiconsulting.co   # omit for localhost
# APP_URL=https://dashboard.umiconsulting.co  # password-reset link base

# ── Cash (live) — QR + customer-auth secrets, MUST equal umi-cash's values ──
# APP_QR_SECRET verifies QR codes on already-issued wallet passes (≥32 chars).
# JWT_ACCESS/REFRESH_SECRET sign the customer session minted at registration.
# WALLET_PASS_PUSH_URL (optional) points at the pass-push service; unset = skip.
# APP_QR_SECRET=                    # ≥32 chars; byte-identical to umi-cash
# JWT_ACCESS_SECRET=                # ≥32 chars; cash customer access token
# JWT_REFRESH_SECRET=               # ≥32 chars; cash customer refresh token
# WALLET_PASS_PUSH_URL=

# ── Added in later phases (kept commented so boot doesn't require them) ─────
# ANTHROPIC_API_KEY=                # Phase 3
# VOYAGE_API_KEY=                   # Phase 3
# TWILIO_ACCOUNT_SID=               # Phase 3
# TWILIO_AUTH_TOKEN=                # Phase 3
# TWILIO_WHATSAPP_FROM=             # Phase 3
# ZETTLE_CLIENT_ID=                 # Phase 3
# ZETTLE_API_KEY=                   # Phase 3
# SMTP_HOST=                        # Phase 2/5 (email)
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=hola@umiconsulting.co
# CONTACT_TO_EMAIL=hola@umiconsulting.co  # Phase 5: landing contact-form recipient
# LEADS_WEBHOOK_SECRET=             # Phase 5: HMAC secret for /api/leads/webhook/email-response
# CORS_ORIGINS=https://dashboard.umiconsulting.co,https://umiconsulting.co
