# 🌐 FILE: .env.example (TEMPLATE)
# =====================================================
# Template for other developers to know what to configure
# This file SHOULD be uploaded to Git as reference
# =====================================================

# 🌍 ENVIRONMENT
NODE_ENV=development

# 📧 EMAIL CONFIGURATION
# Brevo SMTP example
# SMTP_USER is the Brevo "Login" value from SMTP settings.
# SMTP_PASSWORD is the generated Brevo SMTP key, not a Brevo API key or account password.
# Standard Brevo SMTP keys usually start with xsmtpsib- and are shown in full only once.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-smtp-login@smtp-brevo.com
SMTP_PASSWORD=your_brevo_smtp_key
EMAIL_FROM=hola@umiconsulting.co
CONTACT_TO_EMAIL=your-local-recipient@example.com
ADMIN_EMAIL=your-admin-email@example.com
ENABLE_DAILY_REPORTS=true

# 🧪 TESTING EMAIL
TEST_EMAIL=your-personal-email@gmail.com

# ⏰ CRON JOBS
ENABLE_CRON_JOBS=true
RESET_WEEKLY_METRICS=false

# 🌐 URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 🗄️ DATABASE
# DATABASE_TYPE: "sqlite" for local dev, "postgres" for production (Vercel)
DATABASE_TYPE=sqlite
DATABASE_PATH=./data/leads.db

# 🗄️ SUPABASE (required when DATABASE_TYPE=postgres)
# SUPABASE_URL=https://xbudknbimkgjjgohnjgp.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key_here

# =====================================================


# 📋 SETUP INSTRUCTIONS BY ENVIRONMENT:

# 🔧 LOCAL DEVELOPMENT:
# 1. Copy .env.example to .env.local
# 2. Fill in your real values
# 3. npm run dev

# 🚀 PRODUCTION (Vercel):
# 1. Go to your Vercel dashboard
# 2. Settings → Environment Variables
# 3. Add these variables:

# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-smtp-login@smtp-brevo.com
# SMTP_PASSWORD=your_brevo_smtp_key
# EMAIL_FROM=hola@umiconsulting.co
# CONTACT_TO_EMAIL=your-contact-recipient@gmail.com
# ADMIN_EMAIL=your-admin-email@gmail.com
# INTERNAL_API_TOKEN=secure_random_token_here
# NODE_ENV=production

# 🚀 PRODUCTION (VPS/Server):
# 1. Create .env.production file on server
# 2. Configure variables with real values
# 3. Ensure file has 600 permissions (owner read-only)

# Command to set permissions:
# chmod 600 .env.production
