# Copy to .env for local runs. Production secrets live in Supabase Function settings.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Required: operational tables (messages, conversations, pipeline_traces, products, …)
# Cannot use SUPABASE_* name for custom secrets on hosted Edge Functions — use DB_SCHEMA.
DB_SCHEMA=conversaflow
DEFAULT_BUSINESS_ID=
VOYAGE_API_KEY=

# Twilio — mirror these in Supabase Dashboard → Project Settings → Edge Functions → Secrets
# for deployed job-worker (WhatsApp outbox). Local .env is for supabase functions serve / scripts.
# TWILIO_WHATSAPP_FROM: E.164 digits only, no "whatsapp:" prefix (e.g. +14155238886)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
